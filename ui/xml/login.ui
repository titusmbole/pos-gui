<?xml version='1.0' encoding='utf-8'?>
<interface version="1.2">
  <object class="ttk.Frame" id="login_frame">
    <property name="padding">40</property>
    <layout manager="pack">
      <property name="expand">true</property>
      <property name="fill">both</property>
    </layout>

    <!-- Top spacer -->
    <object class="ttk.Frame" id="spacer_top">
      <layout manager="pack">
        <property name="expand">true</property>
        <property name="fill">both</property>
      </layout>
    </object>

    <!-- Center card -->
    <object class="ttk.Labelframe" id="login_card">
      <property name="text">Login</property>
      <property name="padding">30</property>
      <layout manager="pack">
        <property name="padx">100</property>
        <property name="pady">10</property>
      </layout>

      <!-- Title -->
      <object class="ttk.Label" id="title_label">
        <property name="text">POS System</property>
        <property name="font">Arial 22 bold</property>
        <property name="anchor">center</property>
        <layout manager="pack">
          <property name="fill">x</property>
          <property name="pady">0 20</property>
        </layout>
      </object>

      <!-- Subtitle -->
      <object class="ttk.Label" id="subtitle_label">
        <property name="text">Sign in to continue</property>
        <property name="anchor">center</property>
        <layout manager="pack">
          <property name="fill">x</property>
          <property name="pady">0 20</property>
        </layout>
      </object>

      <!-- Username label -->
      <object class="ttk.Label" id="username_label">
        <property name="text">Username</property>
        <property name="anchor">w</property>
        <layout manager="pack">
          <property name="fill">x</property>
          <property name="pady">5 2</property>
        </layout>
      </object>

      <!-- Username entry -->
      <object class="ttk.Entry" id="username_entry">
        <property name="width">30</property>
        <layout manager="pack">
          <property name="fill">x</property>
          <property name="pady">0 10</property>
        </layout>
      </object>

      <!-- Password label -->
      <object class="ttk.Label" id="password_label">
        <property name="text">Password</property>
        <property name="anchor">w</property>
        <layout manager="pack">
          <property name="fill">x</property>
          <property name="pady">5 2</property>
        </layout>
      </object>

      <!-- Password entry -->
      <object class="ttk.Entry" id="password_entry">
        <property name="show">•</property>
        <property name="width">30</property>
        <layout manager="pack">
          <property name="fill">x</property>
          <property name="pady">0 5</property>
        </layout>
      </object>

      <!-- Error message label (hidden by default) -->
      <object class="ttk.Label" id="error_label">
        <property name="text"> </property>
        <property name="foreground">red</property>
        <property name="anchor">center</property>
        <layout manager="pack">
          <property name="fill">x</property>
          <property name="pady">5</property>
        </layout>
      </object>

      <!-- Login button -->
      <object class="ttk.Button" id="login_button">
        <property name="text">Login</property>
        <property name="command">on_login</property>
        <layout manager="pack">
          <property name="fill">x</property>
          <property name="pady">10 5</property>
          <property name="ipady">5</property>
        </layout>
      </object>

      <!-- Footer -->
      <object class="ttk.Label" id="footer_label">
        <property name="text">© 2026 POS System</property>
        <property name="anchor">center</property>
        <property name="foreground">gray</property>
        <layout manager="pack">
          <property name="fill">x</property>
          <property name="pady">15 0</property>
        </layout>
      </object>

    </object>

    <!-- Bottom spacer -->
    <object class="ttk.Frame" id="spacer_bottom">
      <layout manager="pack">
        <property name="expand">true</property>
        <property name="fill">both</property>
      </layout>
    </object>

  </object>
</interface>
