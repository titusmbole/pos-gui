<?xml version='1.0' encoding='utf-8'?>
<interface version="1.2">
  <object class="ttk.Frame" id="pos_frame">
    <layout manager="pack">
      <property name="expand">true</property>
      <property name="fill">both</property>
    </layout>

    <!-- Search bar -->
    <object class="ttk.Labelframe" id="search_frame">
      <property name="text">Search Product</property>
      <layout manager="grid">
        <property name="row">0</property>
        <property name="column">0</property>
        <property name="columnspan">2</property>
        <property name="sticky">ew</property>
        <property name="padx">5</property>
        <property name="pady">5</property>
      </layout>

      <object class="ttk.Entry" id="search_entry">
        <property name="width">40</property>
        <layout manager="pack">
          <property name="side">left</property>
          <property name="padx">5</property>
          <property name="pady">5</property>
        </layout>
      </object>

      <object class="ttk.Button" id="search_button">
        <property name="text">Search</property>
        <property name="command">on_search</property>
        <layout manager="pack">
          <property name="side">left</property>
          <property name="padx">5</property>
        </layout>
      </object>
    </object>

    <!-- Products panel (left) -->
    <object class="ttk.Labelframe" id="prod_frame">
      <property name="text">Products</property>
      <layout manager="grid">
        <property name="row">1</property>
        <property name="column">0</property>
        <property name="sticky">nsew</property>
        <property name="padx">5</property>
        <property name="pady">5</property>
      </layout>

      <object class="ttk.Treeview" id="product_tree">
        <property name="columns">id name price stock</property>
        <property name="show">headings</property>
        <property name="height">15</property>
        <layout manager="pack">
          <property name="fill">both</property>
          <property name="expand">true</property>
          <property name="padx">5</property>
          <property name="pady">5</property>
        </layout>
      </object>

      <object class="ttk.Button" id="add_to_cart_button">
        <property name="text">Add to Cart</property>
        <property name="command">on_add_to_cart</property>
        <layout manager="pack">
          <property name="pady">5</property>
        </layout>
      </object>
    </object>

    <!-- Cart panel (right) -->
    <object class="ttk.Labelframe" id="cart_frame">
      <property name="text">Cart</property>
      <layout manager="grid">
        <property name="row">1</property>
        <property name="column">1</property>
        <property name="sticky">nsew</property>
        <property name="padx">5</property>
        <property name="pady">5</property>
      </layout>

      <object class="ttk.Treeview" id="cart_tree">
        <property name="columns">name qty price subtotal</property>
        <property name="show">headings</property>
        <property name="height">15</property>
        <layout manager="pack">
          <property name="fill">both</property>
          <property name="expand">true</property>
          <property name="padx">5</property>
          <property name="pady">5</property>
        </layout>
      </object>

      <object class="ttk.Frame" id="cart_btn_row">
        <layout manager="pack">
          <property name="pady">5</property>
        </layout>

        <object class="ttk.Button" id="remove_button">
          <property name="text">Remove</property>
          <property name="command">on_remove_from_cart</property>
          <layout manager="pack">
            <property name="side">left</property>
            <property name="padx">5</property>
          </layout>
        </object>

        <object class="ttk.Button" id="clear_cart_button">
          <property name="text">Clear Cart</property>
          <property name="command">on_clear_cart</property>
          <layout manager="pack">
            <property name="side">left</property>
            <property name="padx">5</property>
          </layout>
        </object>
      </object>
    </object>

    <!-- Checkout bar -->
    <object class="ttk.Frame" id="checkout_frame">
      <layout manager="grid">
        <property name="row">2</property>
        <property name="column">0</property>
        <property name="columnspan">2</property>
        <property name="sticky">ew</property>
        <property name="padx">5</property>
        <property name="pady">5</property>
      </layout>

      <object class="ttk.Label" id="total_label">
        <property name="text">Total: $0.00</property>
        <property name="font">Arial 16 bold</property>
        <layout manager="pack">
          <property name="side">left</property>
          <property name="padx">20</property>
        </layout>
      </object>

      <object class="ttk.Radiobutton" id="radio_cash">
        <property name="text">Cash</property>
        <property name="value">cash</property>
        <layout manager="pack">
          <property name="side">left</property>
          <property name="padx">5</property>
        </layout>
      </object>

      <object class="ttk.Radiobutton" id="radio_card">
        <property name="text">Card</property>
        <property name="value">card</property>
        <layout manager="pack">
          <property name="side">left</property>
          <property name="padx">5</property>
        </layout>
      </object>

      <object class="ttk.Button" id="checkout_button">
        <property name="text">Checkout</property>
        <property name="command">on_checkout</property>
        <layout manager="pack">
          <property name="side">right</property>
          <property name="padx">20</property>
        </layout>
      </object>
    </object>

  </object>
</interface>
