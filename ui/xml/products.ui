<?xml version='1.0' encoding='utf-8'?>
<interface version="1.2">
  <object class="ttk.Frame" id="product_frame">
    <layout manager="pack">
      <property name="expand">true</property>
      <property name="fill">both</property>
    </layout>

    <!-- Product Details Form -->
    <object class="ttk.Labelframe" id="form_frame">
      <property name="text">Product Details</property>
      <layout manager="grid">
        <property name="row">0</property>
        <property name="column">0</property>
        <property name="columnspan">2</property>
        <property name="sticky">ew</property>
        <property name="padx">5</property>
        <property name="pady">5</property>
      </layout>

      <!-- Row 0: Labels -->
      <object class="ttk.Label" id="lbl_name">
        <property name="text">Name:</property>
        <layout manager="grid">
          <property name="row">0</property>
          <property name="column">0</property>
          <property name="padx">5</property>
          <property name="pady">5</property>
        </layout>
      </object>
      <object class="ttk.Entry" id="entry_name">
        <property name="width">16</property>
        <layout manager="grid">
          <property name="row">0</property>
          <property name="column">1</property>
          <property name="padx">5</property>
          <property name="pady">5</property>
        </layout>
      </object>

      <object class="ttk.Label" id="lbl_barcode">
        <property name="text">Barcode:</property>
        <layout manager="grid">
          <property name="row">0</property>
          <property name="column">2</property>
          <property name="padx">5</property>
          <property name="pady">5</property>
        </layout>
      </object>
      <object class="ttk.Entry" id="entry_barcode">
        <property name="width">16</property>
        <layout manager="grid">
          <property name="row">0</property>
          <property name="column">3</property>
          <property name="padx">5</property>
          <property name="pady">5</property>
        </layout>
      </object>

      <object class="ttk.Label" id="lbl_price">
        <property name="text">Price:</property>
        <layout manager="grid">
          <property name="row">0</property>
          <property name="column">4</property>
          <property name="padx">5</property>
          <property name="pady">5</property>
        </layout>
      </object>
      <object class="ttk.Entry" id="entry_price">
        <property name="width">16</property>
        <layout manager="grid">
          <property name="row">0</property>
          <property name="column">5</property>
          <property name="padx">5</property>
          <property name="pady">5</property>
        </layout>
      </object>

      <object class="ttk.Label" id="lbl_stock">
        <property name="text">Stock:</property>
        <layout manager="grid">
          <property name="row">0</property>
          <property name="column">6</property>
          <property name="padx">5</property>
          <property name="pady">5</property>
        </layout>
      </object>
      <object class="ttk.Entry" id="entry_stock">
        <property name="width">16</property>
        <layout manager="grid">
          <property name="row">0</property>
          <property name="column">7</property>
          <property name="padx">5</property>
          <property name="pady">5</property>
        </layout>
      </object>

      <object class="ttk.Label" id="lbl_category">
        <property name="text">Category:</property>
        <layout manager="grid">
          <property name="row">0</property>
          <property name="column">8</property>
          <property name="padx">5</property>
          <property name="pady">5</property>
        </layout>
      </object>
      <object class="ttk.Combobox" id="cat_combo">
        <property name="width">14</property>
        <property name="state">readonly</property>
        <layout manager="grid">
          <property name="row">0</property>
          <property name="column">9</property>
          <property name="padx">5</property>
          <property name="pady">5</property>
        </layout>
      </object>

      <!-- Row 1: Buttons -->
      <object class="ttk.Frame" id="btn_frame">
        <layout manager="grid">
          <property name="row">1</property>
          <property name="column">0</property>
          <property name="columnspan">10</property>
          <property name="pady">5</property>
        </layout>

        <object class="ttk.Button" id="btn_new_product">
          <property name="text">+ New Product</property>
          <property name="command">on_open_add_dialog</property>
          <layout manager="pack">
            <property name="side">left</property>
            <property name="padx">5</property>
          </layout>
        </object>

        <object class="ttk.Button" id="btn_add">
          <property name="text">Add</property>
          <property name="command">on_add</property>
          <layout manager="pack">
            <property name="side">left</property>
            <property name="padx">5</property>
          </layout>
        </object>

        <object class="ttk.Button" id="btn_update">
          <property name="text">Update</property>
          <property name="command">on_update</property>
          <layout manager="pack">
            <property name="side">left</property>
            <property name="padx">5</property>
          </layout>
        </object>

        <object class="ttk.Button" id="btn_delete">
          <property name="text">Delete</property>
          <property name="command">on_delete</property>
          <layout manager="pack">
            <property name="side">left</property>
            <property name="padx">5</property>
          </layout>
        </object>

        <object class="ttk.Button" id="btn_clear">
          <property name="text">Clear</property>
          <property name="command">on_clear</property>
          <layout manager="pack">
            <property name="side">left</property>
            <property name="padx">5</property>
          </layout>
        </object>
      </object>
    </object>

    <!-- Product table -->
    <object class="ttk.Treeview" id="product_table">
      <property name="columns">id name barcode price stock category</property>
      <property name="show">headings</property>
      <property name="height">18</property>
      <layout manager="grid">
        <property name="row">1</property>
        <property name="column">0</property>
        <property name="columnspan">2</property>
        <property name="sticky">nsew</property>
        <property name="padx">5</property>
        <property name="pady">5</property>
      </layout>
    </object>

  </object>
</interface>
