<?xml version='1.0' encoding='utf-8'?>
<interface version="1.2">
  <object class="ttk.Frame" id="sales_frame">
    <layout manager="pack">
      <property name="expand">true</property>
      <property name="fill">both</property>
    </layout>

    <!-- Daily Summary -->
    <object class="ttk.Labelframe" id="summary_frame">
      <property name="text">Daily Summary</property>
      <layout manager="grid">
        <property name="row">0</property>
        <property name="column">0</property>
        <property name="sticky">ew</property>
        <property name="padx">5</property>
        <property name="pady">5</property>
      </layout>

      <object class="ttk.Label" id="summary_label">
        <property name="text">Sales: 0 | Revenue: $0.00</property>
        <property name="font">Arial 13</property>
        <layout manager="pack">
          <property name="side">left</property>
          <property name="padx">10</property>
          <property name="pady">5</property>
        </layout>
      </object>

      <object class="ttk.Button" id="refresh_button">
        <property name="text">Refresh</property>
        <property name="command">on_refresh</property>
        <layout manager="pack">
          <property name="side">right</property>
          <property name="padx">10</property>
        </layout>
      </object>
    </object>

    <!-- Sales table -->
    <object class="ttk.Treeview" id="sales_table">
      <property name="columns">id total payment date</property>
      <property name="show">headings</property>
      <property name="height">18</property>
      <layout manager="grid">
        <property name="row">1</property>
        <property name="column">0</property>
        <property name="sticky">nsew</property>
        <property name="padx">5</property>
        <property name="pady">5</property>
      </layout>
    </object>

  </object>
</interface>
